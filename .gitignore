__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
*.egg-info/

# Data & weights (too large for git)
data/*.jsonl
data/images/
weights/*.pt
weights/*.json
weights/*/
*.jsonl
*.pt
# Phase 3 -> Phase 2 contract artifact: canonical exported lookup table.
# Small (~35KB), checked in so Phase 2 retrain has a stable known target.
!weights/emotion_lookup_table.json
# Phase 2 -> pipeline contract artifact: trained MLP projection head.
# Small (~1.6MB), checked in as the deliverable downstream consumers
# (pipeline.py inference path) load directly.
!weights/phase2_mlp.pt

# Outputs
outputs/*.wav
outputs/**/*.wav
outputs/**/filelists/*.txt
outputs/**/vits_train.log
# Stage D / Run 1 listening evaluation samples (committed for reviewers)
!outputs/phase3_new_v1_listening/*.wav
# Stage D Run 2 reproduction listening samples — Path A only (eid-based,
# uses Run 2's own emb_e). Path B (*_override.wav, commit-11-lookup overrides)
# stays ignored as a diagnostic artifact, not a deployed pipeline output.
!outputs/phase3_new_v2_listening/*_eid.wav
# Stage F end-to-end smoke evidence (stub Phase 1 + real Phase 2 v3 + real
# Phase 3 Run 2 G_18000); committed for reviewers.
!outputs/e2e_smoke.wav
# Stage G prep demo set (10 wavs covering 5 emotions x 2 from test split);
# committed for reviewer listening. Per-image SER-eval wavs (ser_e2e_wavs*,
# ser_phase3_isolated_wavs) stay ignored (>150 wavs, regenerable from
# eval scripts).
!outputs/demo/*.wav
# Stage G Run 2 ablation (lambda_cls=0) listening A/B set, Path A only;
# committed for reviewer listening alongside Run 1 / phase3_new_v2_listening.
!outputs/phase3_new_v2_no_cls_listening/*.wav
# Stage G Run 3 ablation (lambda_ortho=0) listening A/B set; committed
# alongside Run 1 + Run 2 for the 3-run ablation matrix.
!outputs/phase3_new_v3_no_ortho_listening/*.wav
# 5-sample exhibit (one image per emotion class) for final report appendix;
# committed alongside outputs/demo/ as additional qualitative evidence.
!outputs/samples/*.wav
# SER eval per-sample metadata (Tasks 1, 2a, 2b); small jsonl files,
# committed alongside the eval JSON summaries. Phase 1 / phase3 raw
# data jsonls under data/ stay ignored via data/*.jsonl above.
!outputs/*.jsonl

# Phase 3 (new) pre-cleaned filelists — generated artifact, regenerable
# from raw filelists via scripts/phase3_new_pre_clean_text.py
data/filelists/*.cleaned.txt

# ESD dataset
ESD/

