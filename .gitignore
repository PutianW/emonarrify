# Data & weights (too large for git)
data/*.jsonl
data/images/
weights/*.pt
weights/*.json
weights/*/
*.jsonl
*.pt
# Phase 3 -> Phase 2 contract artifact: canonical exported lookup table.
# Small (~35KB), checked in so Phase 2 retrain has a stable known target.
!weights/emotion_lookup_table.json
# Phase 2 -> pipeline contract artifact: trained MLP projection head.
# Small (~1.6MB), checked in as the deliverable downstream consumers
# (pipeline.py inference path) load directly.
!weights/phase2_mlp.pt

# Outputs
outputs/*.wav
outputs/**/*.wav
outputs/**/filelists/*.txt
outputs/**/vits_train.log
# Stage D / Run 1 listening evaluation samples (committed for reviewers)
!outputs/phase3_new_v1_listening/*.wav
# Stage D Run 2 reproduction listening samples — Path A only (eid-based,
# uses Run 2's own emb_e). Path B (*_override.wav, commit-11-lookup overrides)
# stays ignored as a diagnostic artifact, not a deployed pipeline output.
!outputs/phase3_new_v2_listening/*_eid.wav

# Phase 3 (new) pre-cleaned filelists — generated artifact, regenerable
# from raw filelists via scripts/phase3_new_pre_clean_text.py
data/filelists/*.cleaned.txt

